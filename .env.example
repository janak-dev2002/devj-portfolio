# devj-portfolio — production environment variables
#
# Copy this file to `.env` on the home server (NOT committed — see .gitignore)
# and fill in real values. `docker compose` (docker-compose.yml) reads this
# file automatically from the current directory.

# ---- PostgreSQL ----
DB_USER=devj_portfolio
DB_PASSWORD=change-me-to-a-strong-password

# ---- Backend / Spring Boot ----
# Comma-separated list of allowed CORS origins. In production this should be
# just the site's own origin (same-origin requests don't need CORS at all,
# but Spring still checks this for safety); keep localhost only for local dev.
APP_CORS_ALLOWED_ORIGINS=https://devj.zoneforty5.tech
# Contact-form sender AND recipient (self-send with Reply-To the visitor) —
# no default in the app on purpose, startup fails loudly if unset.
RECIPIENT_EMAIL=sangeeth.jdev@gmail.com

# ---- AWS SES (contact form email delivery) ----
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- Cloudflare Tunnel ----
# Token for the tunnel created in the Cloudflare Zero Trust dashboard
# (Networks -> Tunnels). See shared/agent-handoffs/devops-done.md for the
# exact steps to create it. Never commit the real token.
CLOUDFLARE_TUNNEL_TOKEN=
