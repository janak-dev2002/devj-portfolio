# Copy to inventory.ini (gitignored) and fill in the real host.
#
# This is the shared production VPS (static IP) that also runs the SMR
# Price Dashboard project — not a dedicated/fresh host.
[production]
devj-prod ansible_host=YOUR_SERVER_IP_OR_HOSTNAME ansible_user=YOUR_SSH_USER

[production:vars]
ansible_python_interpreter=/usr/bin/python3
